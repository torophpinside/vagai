# VagAI - Environment Configuration
# Copy this file to .env and update the values

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=vagai
DB_PASSWORD=change-me-in-production
DB_NAME=vagai

# JWT Authentication
JWT_SECRET=change-me-to-a-random-secure-string-at-least-32-chars

# LM Studio AI (local LLM)
LMSTUDIO_URL=http://127.0.0.1:1234

# Redis (caching, rate limiting)
REDIS_URL=redis://localhost:6379

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLIC_KEY=pk_test_...

# Email (Resend/SendGrid)
EMAIL_API_KEY=
EMAIL_FROM=noreply@vagai.com

# App
APP_ENV=development
APP_PORT=8080
